<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="ejercicios.ej10.VentanaPrincipal">
  <grid id="27dc6" binding="panel1" default-binding="true" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
